# ─── Voyager AI – Environment Configuration ───────────────────────
# Copy this file to .env and fill in your values

# AI Keys (optional – app works with mock data without them)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (CHANGE THIS in production!)
JWT_SECRET_KEY=voyager-ai-super-secret-change-me-now

# Database (SQLite default – change to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./voyager.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/voyager_ai

# Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
MAPBOX_TOKEN=your_mapbox_token_here

# Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
